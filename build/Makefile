.PHONY : tests/test_time.s

# target to generate assembly for a file
tests/test_time.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_time.dir/build.make CMakeFiles/test_time.dir/tests/test_time.cpp.s
.PHONY : tests/test_time.cpp.s

